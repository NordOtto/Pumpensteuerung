# MQTT (bestehender Broker, NICHT lokal auf Pi)
MQTT_BROKER=192.168.1.136
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=
MQTT_TOPIC_PREFIX=pumpensteuerung

# Modbus RTU (V20)
# Variante A — bestehender TTL-RS485-Adapter direkt am Pi-UART:
#   /boot/firmware/config.txt: enable_uart=1, dtoverlay=disable-bt → /dev/ttyAMA0
#   Verkabelung: Adapter VCC→3.3V, GND, RXD→Pi GPIO14 (TXD, Pin 8), TXD→Pi GPIO15 (RXD, Pin 10)
# Variante B — USB-RS485-Stick (galvanisch isoliert empfohlen):
#   /dev/ttyUSB0
RTU_PORT=/dev/ttyAMA0
RTU_BAUD=9600
RTU_SLAVE=1

# Modbus TCP-Server (LOGO schreibt hier rein)
TCP_HOST=0.0.0.0
TCP_PORT=502

# Speicherpfade
DATA_DIR=/var/lib/pumpe/data
DB_PATH=/var/lib/pumpe/state.db

# API
API_HOST=127.0.0.1
API_PORT=8000

# Auth (admin/admin beim ersten Login → Wechsel erzwungen)
AUTH_DISABLED=false

TZ=Europe/Berlin
